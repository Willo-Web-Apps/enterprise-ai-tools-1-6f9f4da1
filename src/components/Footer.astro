---
const year = new Date().getFullYear();
---
<footer class="bg-[oklch(0.14_0.055_250)] border-t border-white/[0.07]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-10 border-b border-white/[0.07]">
      <!-- Brand column -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="1" y="1" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.9"/>
            <rect x="13" y="1" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.45"/>
            <rect x="1" y="13" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.45"/>
            <rect x="13" y="13" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.20"/>
          </svg>
          <span class="text-[15px] font-semibold text-white font-display">Stackwise</span>
        </div>
        <p class="text-[13px] text-white/40 leading-relaxed max-w-[200px]">Enterprise AI, Intelligently Curated.</p>
        <p class="mt-4 text-[12px] text-white/25 font-mono tracking-wider uppercase">SOC 2 Type II · ISO 27001</p>
      </div>

      <!-- Platform -->
      <div>
        <p class="text-[11px] font-semibold text-white/30 uppercase tracking-widest mb-4">Platform</p>
        <ul class="space-y-2.5">
          <li><a href="#features" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">AI Tool Intelligence</a></li>
          <li><a href="#features" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Compliance Vetting</a></li>
          <li><a href="#features" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">ROI Benchmarks</a></li>
          <li><a href="#features" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Integration Maps</a></li>
        </ul>
      </div>

      <!-- Solutions -->
      <div>
        <p class="text-[11px] font-semibold text-white/30 uppercase tracking-widest mb-4">Solutions</p>
        <ul class="space-y-2.5">
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">For CIOs</a></li>
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">IT Procurement</a></li>
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Digital Transformation</a></li>
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Engineering Leadership</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-[11px] font-semibold text-white/30 uppercase tracking-widest mb-4">Company</p>
        <ul class="space-y-2.5">
          <li><a href="/blog" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Blog</a></li>
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Security</a></li>
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Privacy Policy</a></li>
          <li><a href="#cta" class="text-[13px] text-white/50 hover:text-white/80 transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-[12px] text-white/25">&copy; {year} Stackwise, Inc. All rights reserved.</p>
      <p class="text-[12px] text-white/20 font-mono">Enterprise AI Intelligence Platform · v2.0</p>
    </div>
  </div>
</footer>
