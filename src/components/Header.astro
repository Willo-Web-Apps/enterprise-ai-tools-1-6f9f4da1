---
---
<header class="sticky top-0 z-50 border-b border-white/[0.08] bg-[oklch(0.17_0.06_250)]/90 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Stackwise home">
      <!-- Inline logo mark: teal bracket + wordmark -->
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="1" y="1" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.9"/>
        <rect x="13" y="1" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.45"/>
        <rect x="1" y="13" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.45"/>
        <rect x="13" y="13" width="8" height="8" rx="1.5" fill="oklch(0.72 0.12 192)" opacity="0.20"/>
      </svg>
      <span class="text-[15px] font-semibold tracking-tight text-white font-display">Stackwise</span>
    </a>

    <!-- Primary nav links (desktop) -->
    <div class="hidden md:flex items-center gap-7">
      <a href="#features" class="text-[13px] font-medium text-white/55 hover:text-white/90 transition-colors duration-150 tracking-wide">Platform</a>
      <a href="#problem" class="text-[13px] font-medium text-white/55 hover:text-white/90 transition-colors duration-150 tracking-wide">Why Stackwise</a>
      <a href="#trust" class="text-[13px] font-medium text-white/55 hover:text-white/90 transition-colors duration-150 tracking-wide">Security</a>
      <a href="#cta" class="text-[13px] font-medium text-white/55 hover:text-white/90 transition-colors duration-150 tracking-wide">Pricing</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#cta" class="hidden sm:inline-block text-[13px] font-medium text-white/60 hover:text-white transition-colors duration-150">Sign in</a>
      <a href="#cta" class="inline-flex items-center gap-1.5 text-[13px] font-semibold bg-brand-500 text-[oklch(0.14_0.05_250)] px-4 py-2 rounded hover:bg-brand-400 transition-colors duration-150 tracking-wide">
        Request Access
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </nav>
</header>
