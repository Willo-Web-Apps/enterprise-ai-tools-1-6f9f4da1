---
import Base from '../layouts/Base.astro';
---
<Base
  title="Stackwise — Enterprise AI Intelligence Platform"
  description="Stackwise curates 14,000+ AI tools with compliance, security, and ROI data enterprise buyers need to decide with confidence."
>

  <!-- =====================================================================
       HERO — Deep navy, data-grid overlay, asymmetric teal glow
       ===================================================================== -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden hero-noise bg-[oklch(0.17_0.06_250)]">

    <!-- Layered gradient background -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <!-- Base navy floor -->
      <div class="absolute inset-0 bg-[oklch(0.17_0.06_250)]"></div>

      <!-- Primary teal glow — top-right, large ellipse -->
      <div class="absolute -top-40 right-[-10%] w-[70vw] h-[70vw] max-w-[900px] max-h-[900px] rounded-full animate-pulse-glow"
           style="background: radial-gradient(ellipse at center, oklch(0.72 0.12 192 / 0.13) 0%, transparent 65%);">
      </div>

      <!-- Secondary glow — mid-left, navy-blue -->
      <div class="absolute top-[30%] -left-[15%] w-[55vw] h-[55vw] max-w-[700px] max-h-[700px] rounded-full"
           style="background: radial-gradient(ellipse at center, oklch(0.35 0.09 230 / 0.22) 0%, transparent 65%);">
      </div>

      <!-- Tertiary glow — bottom center -->
      <div class="absolute bottom-[-10%] left-[30%] w-[50vw] h-[40vw] max-w-[640px]"
           style="background: radial-gradient(ellipse at center, oklch(0.72 0.12 192 / 0.07) 0%, transparent 60%);">
      </div>

      <!-- Angular conic sweep for depth -->
      <div class="absolute inset-0 opacity-30"
           style="background: conic-gradient(from 210deg at 75% 25%, oklch(0.25 0.06 240 / 0.5) 0deg, transparent 60deg, transparent 360deg);">
      </div>

      <!-- Data-grid overlay pattern -->
      <div class="absolute inset-0 hero-grid-overlay opacity-70"></div>

      <!-- Bottom fade to transition cleanly -->
      <div class="absolute bottom-0 left-0 right-0 h-32"
           style="background: linear-gradient(to bottom, transparent, oklch(0.17 0.06 250));">
      </div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">

        <!-- Eyebrow label -->
        <div class="animate-slide-up mb-6 inline-flex items-center gap-2 px-3 py-1.5 rounded border border-brand-500/30 bg-brand-500/10 backdrop-blur-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
          <span class="text-[11px] font-semibold text-brand-400 tracking-widest uppercase">Enterprise AI Intelligence</span>
        </div>

        <!-- Hero headline -->
        <h1 class="animate-slide-up delay-100 font-display font-bold text-white leading-[1.08] tracking-tight" style="font-size: clamp(2.4rem, 5.5vw, 4.2rem);">
          The AI Intelligence Platform<br>
          <span class="text-brand-500">Built for Enterprise Teams</span>
        </h1>

        <!-- Hero sub -->
        <p class="animate-slide-up delay-200 mt-6 text-[17px] md:text-[18px] text-white/60 leading-relaxed max-w-[540px] font-body font-light">
          Stackwise curates 14,000+ AI tools with the compliance, security, and ROI data enterprise buyers actually need to decide with confidence.
        </p>

        <!-- CTAs -->
        <div class="animate-slide-up delay-300 mt-9 flex flex-col sm:flex-row gap-3">
          <a href="#cta"
             class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-brand-500 text-[oklch(0.14_0.055_250)] text-[14px] font-semibold rounded hover:bg-brand-400 transition-colors duration-150 tracking-wide">
            Request Enterprise Access
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#problem"
             class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/20 text-white/80 text-[14px] font-medium rounded hover:border-white/40 hover:text-white transition-colors duration-150 tracking-wide">
            See How It Works
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="animate-slide-up delay-400 mt-5 text-[12px] text-white/30 tracking-wide">
          Trusted by procurement teams at Fortune 500 companies · No credit card required
        </p>
      </div>

      <!-- Floating data card — desktop only, decorative -->
      <div class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 w-[340px] animate-fade-in delay-500"
           aria-hidden="true">
        <div class="rounded-lg border border-white/[0.10] bg-white/[0.04] backdrop-blur-sm p-5 font-mono text-[12px] text-white/60 shadow-2xl">
          <div class="flex items-center justify-between mb-4">
            <span class="text-brand-400 font-semibold text-[11px] tracking-widest uppercase">Tool Analysis Report</span>
            <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
          </div>
          <div class="space-y-2.5">
            <div class="flex justify-between border-b border-white/[0.06] pb-2">
              <span class="text-white/40">Vendor</span>
              <span class="text-white/75">Acme AI Copilot</span>
            </div>
            <div class="flex justify-between border-b border-white/[0.06] pb-2">
              <span class="text-white/40">SOC 2 Type II</span>
              <span class="text-brand-400 font-semibold">✓ Verified</span>
            </div>
            <div class="flex justify-between border-b border-white/[0.06] pb-2">
              <span class="text-white/40">GDPR</span>
              <span class="text-brand-400 font-semibold">✓ Compliant</span>
            </div>
            <div class="flex justify-between border-b border-white/[0.06] pb-2">
              <span class="text-white/40">ROI Benchmark</span>
              <span class="text-white/75">+34% efficiency</span>
            </div>
            <div class="flex justify-between border-b border-white/[0.06] pb-2">
              <span class="text-white/40">Enterprise Fit</span>
              <span class="text-white/75">High — 2,400+ seats</span>
            </div>
            <div class="flex justify-between">
              <span class="text-white/40">Integration</span>
              <span class="text-white/75">Salesforce, SAP, Azure</span>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-white/[0.06] flex items-center gap-2">
            <div class="flex-1 h-1.5 bg-white/[0.08] rounded-full overflow-hidden">
              <div class="h-full w-[82%] bg-brand-500/70 rounded-full"></div>
            </div>
            <span class="text-brand-400 text-[11px] font-semibold">82 / 100</span>
          </div>
          <p class="mt-1.5 text-[10px] text-white/25">Enterprise Readiness Score</p>
        </div>
      </div>
    </div>
  </section>


  <!-- =====================================================================
       STATS BAR — Data proof belt below hero
       ===================================================================== -->
  <section class="bg-[oklch(0.21_0.055_250)] border-b border-white/[0.07]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-white/[0.07]">

        <div class="px-8 py-7 flex flex-col gap-1">
          <span class="tabular-nums font-display font-bold text-brand-500 tracking-tight" style="font-size: 2.2rem; line-height:1;">14,000+</span>
          <span class="text-[12px] text-white/45 font-body uppercase tracking-widest">AI Tools Curated</span>
        </div>

        <div class="px-8 py-7 flex flex-col gap-1">
          <span class="tabular-nums font-display font-bold text-brand-500 tracking-tight" style="font-size: 2.2rem; line-height:1;">78%</span>
          <span class="text-[12px] text-white/45 font-body uppercase tracking-widest">Enterprise Adoption Rate</span>
        </div>

        <div class="px-8 py-7 flex flex-col gap-1">
          <span class="tabular-nums font-display font-bold text-brand-500 tracking-tight" style="font-size: 2.2rem; line-height:1;">34%</span>
          <span class="text-[12px] text-white/45 font-body uppercase tracking-widest">Industry CAGR</span>
        </div>

        <div class="px-8 py-7 flex flex-col gap-1">
          <span class="tabular-nums font-display font-bold text-brand-500 tracking-tight" style="font-size: 2.2rem; line-height:1;">4.8×</span>
          <span class="text-[12px] text-white/45 font-body uppercase tracking-widest">Avg. Procurement ROI</span>
        </div>

      </div>
    </div>
  </section>


  <!-- =====================================================================
       LOGO / TRUST BAR — Enterprise logos and certifications
       ===================================================================== -->
  <section id="trust" class="bg-[oklch(0.97_0.008_250)] border-b border-[oklch(0.90_0.006_250)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <p class="text-center text-[11px] font-semibold uppercase tracking-widest text-[oklch(0.52_0.025_250)] mb-8">
        Trusted by procurement and engineering leaders at
      </p>
      <!-- Simulated enterprise client logos using text-based treatment -->
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6">
        <span class="font-display font-semibold text-[oklch(0.60_0.015_250)] text-[15px] tracking-tight opacity-60">Accenture</span>
        <span class="font-display font-semibold text-[oklch(0.60_0.015_250)] text-[15px] tracking-tight opacity-60">Deloitte</span>
        <span class="font-display font-semibold text-[oklch(0.60_0.015_250)] text-[15px] tracking-tight opacity-60">JPMorgan Chase</span>
        <span class="font-display font-semibold text-[oklch(0.60_0.015_250)] text-[15px] tracking-tight opacity-60">Lockheed Martin</span>
        <span class="font-display font-semibold text-[oklch(0.60_0.015_250)] text-[15px] tracking-tight opacity-60">Siemens AG</span>
        <span class="font-display font-semibold text-[oklch(0.60_0.015_250)] text-[15px] tracking-tight opacity-60">GSK</span>
      </div>

      <!-- Compliance badges -->
      <div class="mt-8 flex flex-wrap justify-center items-center gap-4">
        <!-- SOC 2 -->
        <div class="flex items-center gap-2 px-4 py-2 rounded border border-[oklch(0.87_0.04_192)] bg-[oklch(0.96_0.018_192)] text-[oklch(0.50_0.10_192)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill="currentColor" fill-opacity="0.12"/>
            <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-[11px] font-semibold tracking-wide">SOC 2 Type II</span>
        </div>
        <!-- ISO 27001 -->
        <div class="flex items-center gap-2 px-4 py-2 rounded border border-[oklch(0.87_0.04_192)] bg-[oklch(0.96_0.018_192)] text-[oklch(0.50_0.10_192)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.12"/>
            <path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span class="text-[11px] font-semibold tracking-wide">ISO 27001</span>
        </div>
        <!-- GDPR -->
        <div class="flex items-center gap-2 px-4 py-2 rounded border border-[oklch(0.87_0.04_192)] bg-[oklch(0.96_0.018_192)] text-[oklch(0.50_0.10_192)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.12"/>
            <path d="M8 11V7a4 4 0 0 1 8 0v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span class="text-[11px] font-semibold tracking-wide">GDPR Compliant</span>
        </div>
        <!-- FedRAMP -->
        <div class="flex items-center gap-2 px-4 py-2 rounded border border-[oklch(0.87_0.04_192)] bg-[oklch(0.96_0.018_192)] text-[oklch(0.50_0.10_192)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 21h18M5 21V10l7-7 7 7v11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="currentColor" fill-opacity="0.12"/>
            <rect x="9" y="15" width="6" height="6" stroke="currentColor" stroke-width="1.6"/>
          </svg>
          <span class="text-[11px] font-semibold tracking-wide">FedRAMP Ready</span>
        </div>
      </div>
    </div>
  </section>


  <!-- =====================================================================
       PROBLEM → SOLUTION — The competitive argument
       ===================================================================== -->
  <section id="problem" class="bg-[oklch(0.97_0.008_250)] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="max-w-2xl mb-14">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-500 mb-3">The Intelligence Gap</p>
        <h2 class="font-display font-bold text-[oklch(0.17_0.06_250)] leading-tight tracking-tight" style="font-size: clamp(1.9rem, 4vw, 3rem);">
          Generic directories weren't built for enterprise decisions
        </h2>
      </div>

      <!-- Split comparison grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- LEFT — What competitors miss (muted / problem) -->
        <div class="rounded-lg border border-[oklch(0.87_0.006_250)] bg-white p-8">
          <div class="flex items-center gap-2 mb-6">
            <div class="w-5 h-5 rounded-full flex items-center justify-center bg-[oklch(0.93_0.03_20)] text-[oklch(0.55_0.15_20)]">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M2 2l6 6M8 2L2 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <span class="text-[13px] font-semibold text-[oklch(0.40_0.015_250)] uppercase tracking-wide">Generic AI Directories</span>
          </div>
          <ul class="space-y-4">
            {[
              "Star ratings from individual users — not enterprise procurement criteria",
              "No compliance data: unknown SOC 2, GDPR, or FedRAMP status",
              "No integration maps for Salesforce, SAP, Azure, or existing stacks",
              "No verified ROI benchmarks — only marketing claims from vendors",
              "Designed for curious individuals, not defensible investment decisions",
              "Cluttered, consumer-web layouts that waste decision-makers' time",
            ].map(item => (
              <li class="flex gap-3 text-[14px] text-[oklch(0.52_0.025_250)] leading-snug">
                <svg class="shrink-0 mt-0.5 w-4 h-4 text-[oklch(0.70_0.04_20)] opacity-70" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity="0"/>
                  <path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- RIGHT — What Stackwise delivers (teal / solution) -->
        <div class="rounded-lg border border-brand-200 bg-[oklch(0.97_0.008_192)] p-8">
          <div class="flex items-center gap-2 mb-6">
            <div class="w-5 h-5 rounded-full flex items-center justify-center bg-brand-500/15 text-brand-600">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M2 5.5l2.5 2.5 4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="text-[13px] font-semibold text-[oklch(0.40_0.10_192)] uppercase tracking-wide">Stackwise Enterprise Intelligence</span>
          </div>
          <ul class="space-y-4">
            {[
              "Enterprise readiness scores built on verified compliance and security certifications",
              "Full compliance metadata: SOC 2, ISO 27001, GDPR, HIPAA, and FedRAMP statuses",
              "Integration maps for 200+ enterprise systems — Salesforce, Azure, SAP, ServiceNow",
              "Verified ROI benchmarks from peer deployments across similar industries",
              "Purpose-built for CIOs, procurement, and VPs who own technology budgets",
              "Data-dense, decision-grade interface designed for professional use",
            ].map(item => (
              <li class="flex gap-3 text-[14px] text-[oklch(0.30_0.06_250)] leading-snug">
                <svg class="shrink-0 mt-0.5 w-4 h-4 text-brand-500" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2" fill="currentColor" fill-opacity="0.08"/>
                  <path d="M5 8.5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- =====================================================================
       FEATURES — Platform capabilities
       ===================================================================== -->
  <section id="features" class="bg-[oklch(0.22_0.055_250)] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-14">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-500 mb-3">Platform Capabilities</p>
        <h2 class="font-display font-bold text-white leading-tight tracking-tight" style="font-size: clamp(1.9rem, 4vw, 3rem);">
          Every data point enterprises require,<br>before you sign a contract
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">

        <!-- Feature 1 — Compliance Intelligence -->
        <div class="group rounded-lg border border-white/[0.08] bg-white/[0.03] p-7 hover:border-brand-500/40 hover:bg-white/[0.05] transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-400">
              <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill="currentColor" fill-opacity="0.1"/>
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-white text-[16px] mb-2">Compliance Intelligence</h3>
          <p class="text-[14px] text-white/50 leading-relaxed">Verified SOC 2, ISO 27001, GDPR, HIPAA, and FedRAMP certification status for every tool — sourced directly, not self-reported.</p>
        </div>

        <!-- Feature 2 — Security Vetting -->
        <div class="group rounded-lg border border-white/[0.08] bg-white/[0.03] p-7 hover:border-brand-500/40 hover:bg-white/[0.05] transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-400">
              <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.1"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <circle cx="12" cy="16" r="1.5" fill="currentColor"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-white text-[16px] mb-2">Security Risk Flags</h3>
          <p class="text-[14px] text-white/50 leading-relaxed">Data residency, model training data practices, third-party access policies, and breach history — all surfaced before procurement.</p>
        </div>

        <!-- Feature 3 — ROI Benchmarks -->
        <div class="group rounded-lg border border-white/[0.08] bg-white/[0.03] p-7 hover:border-brand-500/40 hover:bg-white/[0.05] transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-400">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="16 7 22 7 22 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-white text-[16px] mb-2">Verified ROI Benchmarks</h3>
          <p class="text-[14px] text-white/50 leading-relaxed">Peer-sourced efficiency gains, cost reduction figures, and payback periods from verified enterprise deployments in your industry.</p>
        </div>

        <!-- Feature 4 — Integration Maps -->
        <div class="group rounded-lg border border-white/[0.08] bg-white/[0.03] p-7 hover:border-brand-500/40 hover:bg-white/[0.05] transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-400">
              <circle cx="18" cy="5" r="3" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.1"/>
              <circle cx="6" cy="12" r="3" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.1"/>
              <circle cx="18" cy="19" r="3" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.1"/>
              <path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-white text-[16px] mb-2">Integration Maps</h3>
          <p class="text-[14px] text-white/50 leading-relaxed">Pre-built connector data for 200+ enterprise platforms: Salesforce, SAP, Azure AD, ServiceNow, Workday, and your existing stack.</p>
        </div>

        <!-- Feature 5 — Procurement Workflows -->
        <div class="group rounded-lg border border-white/[0.08] bg-white/[0.03] p-7 hover:border-brand-500/40 hover:bg-white/[0.05] transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-brand-500/15 flex items-center justify-center mb-5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-brand-400">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.1"/>
              <path d="M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
